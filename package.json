{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ulimit -n 10240 2>/dev/null || true; next dev -H 0.0.0.0",
    "dev:3004": "ulimit -n 10240 2>/dev/null || true; next dev -H 127.0.0.1 -p 3004",
    "dev:3004:restart": "lsof -ti :3004 | xargs kill -9 2>/dev/null; rm -rf .next 2>/dev/null; npm run dev:3004",
    "dev:fresh": "rm -rf .next && (ulimit -n 10240 2>/dev/null || true) && next dev -H 0.0.0.0",
    "dev:restart": "lsof -ti :3000 | xargs kill -9 2>/dev/null; npm run dev",
    "build": "next build",
    "pages:build": "VERCEL_CLI_CONFIG_DIR=.vercel/cli next build && next-on-pages",
    "start": "next start -H 127.0.0.1",
    "prod": "npm run build && next start -H 127.0.0.1 -p 3005",
    "preview": "npm run build && next start -H 127.0.0.1 -p 3004",
    "lint": "eslint ."
  },
  "dependencies": {
    "framer-motion": "^12.35.2",
    "next": "15.5.2",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@cloudflare/next-on-pages": "^1.13.16",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
